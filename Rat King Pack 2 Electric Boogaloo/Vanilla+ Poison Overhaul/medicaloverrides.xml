    <Description textidentifier="afflictiondescription.morbusinepoisoning" target="OtherCharacter" minstrength="50" maxstrength="100" />
    <!--  Cause organ damage for the victim  -->
    <Effect minstrength="0" maxstrength="10" strengthchange="-0.5" minchromaticaberration="0.0" maxchromaticaberration="0.2" minspeedmultiplier="1.0" maxspeedmultiplier="0.9">
      <!--  Wears off slowly regardless of strength  -->
      <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true">
        <Affliction identifier="oxygenlow" amount="10" />
      </StatusEffect>
    </Effect>
    <!--  lethal after str 10  -->
    <Effect minstrength="11" maxstrength="20" strengthchange="-0.5" minscreendistort="0.1" maxscreendistort="0.1" minchromaticaberration="0.2" maxchromaticaberration="0.2" minspeedmultiplier="0.9" maxspeedmultiplier="0.9" tag="poisoned">
      <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true">
        <!--  Don't suffocate just yet -->
        <Affliction identifier="oxygenlow" amount="11" />
      </StatusEffect>
      <StatusEffect target="Character">
        <Conditional NeedsAir="false" />
        <Affliction identifier="organdamage" amount="2" />
      </StatusEffect>
    </Effect>
    <Effect minstrength="21" maxstrength="30" strengthchange="-0.5" minscreendistort="0.1" maxscreendistort="1.0" minchromaticaberration="0.2" maxchromaticaberration="2.0" minspeedmultiplier="0.9" maxspeedmultiplier="0.5" tag="poisoned">

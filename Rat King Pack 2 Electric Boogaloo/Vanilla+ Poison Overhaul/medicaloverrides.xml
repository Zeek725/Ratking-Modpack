      </StatusEffect>
      <StatusEffect target="Character">
        <Conditional NeedsAir="false" />
        <Affliction identifier="organdamage" amount="6" />
      </StatusEffect>
    </Effect>
    <Effect minstrength="41" maxstrength="50" strengthchange="-0.5" minscreendistort="1.0" maxscreendistort="1.0" minchromaticaberration="2.0" maxchromaticaberration="2.0" minspeedmultiplier="0.5" maxspeedmultiplier="0.2" tag="poisoned">
